 	    (state_val & NODE_STATE_DRAIN)) {
@@ -4988,6 +5090,8 @@ extern int create_dynamic_reg_node(slurm_msg_t *msg)

 	node_ptr->node_state |= NODE_STATE_DYNAMIC_NORM;

+reconfigure:
