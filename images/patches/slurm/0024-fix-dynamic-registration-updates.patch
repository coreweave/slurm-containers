+	/*
+	 * If the node already exists, update its config and skip creation.
+	 */
+	if ((node_ptr = find_node_record(reg_msg->node_name))) {
+		if (_update_dynamic_node_config(node_ptr, conf_node, reg_msg))
+			goto reconfigure;
+		s_p_hashtbl_destroy(node_hashtbl);
+		return SLURM_SUCCESS;
+	}
+
+	if (conf_node) {
 		config_ptr = config_record_from_conf_node(conf_node,
 							  slurmctld_tres_cnt);
 		if (conf_node->state)
@@ -4973,8 +5077,6 @@ extern int create_dynamic_reg_node(slurm_msg_t *msg)
 		topology_g_add_rm_node(node_ptr);
 	}

-	_queue_consolidate_config_list();
