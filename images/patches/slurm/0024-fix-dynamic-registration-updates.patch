+/*
+ * Update an existing dynamic node's hardware config from re-registration.
+ * Splits the config record if it's shared with other nodes.
+ */
+static bool _update_dynamic_node_config(
+	node_record_t *node_ptr,
+	slurm_conf_node_t *conf_node,
+	slurm_node_registration_status_msg_t *reg_msg)
+{
+	config_record_t *config_ptr = node_ptr->config_ptr;
+	uint64_t new_real_memory;
+	uint16_t new_boards, new_cores, new_cpus, new_threads, new_tot_sockets;
+	uint32_t new_tmp_disk;
+
+	if (conf_node) {
+		new_real_memory = conf_node->real_memory;
+		new_boards = conf_node->boards;
+		new_cores = conf_node->cores;
+		new_cpus = conf_node->cpus;
+		new_threads = conf_node->threads;
+		new_tot_sockets = conf_node->tot_sockets;
+		new_tmp_disk = conf_node->tmp_disk;
+	} else {
+		new_real_memory = reg_msg->real_memory;
+		new_boards = reg_msg->boards;
+		new_cores = reg_msg->cores;
+		new_cpus = reg_msg->cpus;
+		new_threads = reg_msg->threads;
+		new_tot_sockets = reg_msg->sockets;
+		new_tmp_disk = reg_msg->tmp_disk;
+	}
+
+	if (config_ptr->real_memory == new_real_memory &&
+	    config_ptr->boards == new_boards &&
+	    config_ptr->cores == new_cores &&
+	    config_ptr->cpus == new_cpus &&
+	    config_ptr->threads == new_threads &&
+	    config_ptr->tot_sockets == new_tot_sockets &&
+	    config_ptr->tmp_disk == new_tmp_disk)
+		return false;
+
+	debug("Node %s dynamic config changed, updating (RealMemory: %"PRIu64"->%"PRIu64", CPUs: %u->%u)",
+	      reg_msg->node_name,
+	      config_ptr->real_memory, new_real_memory,
+	      config_ptr->cpus, new_cpus);
+
+	/*
+	 * Config record may be shared with other nodes after consolidation.
+	 * Split it so we only update this node's config.
+	 */
+	if ((bit_set_count(config_ptr->node_bitmap) > 1) &&
+	    bit_test(config_ptr->node_bitmap, node_ptr->index)) {
+		config_record_t *new_config_ptr = _dup_config(config_ptr);
+		bit_clear(config_ptr->node_bitmap, node_ptr->index);
+		xfree(config_ptr->nodes);
+		config_ptr->nodes =
+			bitmap2node_name(config_ptr->node_bitmap);
+		new_config_ptr->node_bitmap = bit_alloc(node_record_count);
+		bit_set(new_config_ptr->node_bitmap, node_ptr->index);
+		xfree(new_config_ptr->nodes);
+		new_config_ptr->nodes = xstrdup(node_ptr->name);
+		node_ptr->config_ptr = new_config_ptr;
+		config_ptr = new_config_ptr;
+	}
+
+	config_ptr->real_memory = new_real_memory;
+	config_ptr->boards = new_boards;
+	config_ptr->cores = new_cores;
+	config_ptr->cpus = new_cpus;
+	config_ptr->threads = new_threads;
+	config_ptr->tot_sockets = new_tot_sockets;
+	config_ptr->tmp_disk = new_tmp_disk;
+
+	node_ptr->real_memory = config_ptr->real_memory;
+	node_ptr->boards = config_ptr->boards;
+	node_ptr->cores = config_ptr->cores;
+	node_ptr->cpus = config_ptr->cpus;
+	node_ptr->threads = config_ptr->threads;
+	node_ptr->tot_sockets = config_ptr->tot_sockets;
+	node_ptr->tot_cores = config_ptr->tot_sockets * config_ptr->cores;
+	node_ptr->tmp_disk = config_ptr->tmp_disk;
+
+	if (node_ptr->tot_cores >= config_ptr->cpus)
+		node_ptr->tpc = 1;
+	else
+		node_ptr->tpc = config_ptr->threads;
+	node_ptr->cpus_efctv = node_ptr->cpus -
+		(node_ptr->core_spec_cnt * node_ptr->tpc);
+
+	return true;
+}
