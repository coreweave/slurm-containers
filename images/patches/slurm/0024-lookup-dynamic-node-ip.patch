-static char *_get_msg_hostname(slurm_msg_t *msg)
+/*
+ * Get the communication address for an incoming message.
+ * For dynamic nodes, try DNS lookup on the provided hostname first.
+ * This allows containerized environments (e.g., Kubernetes) to use
+ * DNS/Services for node addressing instead of relying on the TCP
+ * connection's source IP. Falls back to connection source IP if
+ * DNS resolution fails or hostname is not provided.
+ */
+static char *_get_msg_hostname(slurm_msg_t *msg, const char *hostname)
 {
 	slurm_addr_t *addr = &msg->address;
 	char *name = NULL;

+	/* Try DNS lookup on hostname first */
+	if (hostname && hostname[0]) {
+		struct addrinfo *dns_result;
+		dns_result = xgetaddrinfo_port(hostname,
+					       slurm_conf.slurmd_port);
+		if (dns_result) {
+			name = xmalloc(INET6_ADDRSTRLEN);
+			if (dns_result->ai_family == AF_INET6) {
+				struct sockaddr_in6 *sin6 =
+					(struct sockaddr_in6 *)dns_result->ai_addr;
+				inet_ntop(AF_INET6, &sin6->sin6_addr,
+					  name, INET6_ADDRSTRLEN);
+			} else {
+				struct sockaddr_in *sin =
+					(struct sockaddr_in *)dns_result->ai_addr;
+				inet_ntop(AF_INET, &sin->sin_addr,
+					  name, INET6_ADDRSTRLEN);
+			}
+			freeaddrinfo(dns_result);
+			debug2("%s: Resolved hostname %s to %s",
+			       __func__, hostname, name);
+			return name;
+		}
+	}
+
+	/* Fall back to connection source IP */
 	if (addr->ss_family == AF_UNSPEC) {
 		int fd = conn_g_get_fd(msg->tls_conn);
 		(void) slurm_get_peer_addr(fd, addr);
